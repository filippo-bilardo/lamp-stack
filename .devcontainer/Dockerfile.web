FROM php:8.2-apache

# Abilita mod_rewrite
RUN a2enmod rewrite

# Installa estensioni PHP per MySQL
RUN docker-php-ext-install mysqli pdo pdo_mysql

# Strumenti utili e sudo (necessario per postCreateCommand)
RUN apt-get update && apt-get install -y \
    git curl vim unzip sudo \
    && rm -rf /var/lib/apt/lists/*

# Permetti a www-data di eseguire sudo senza password
RUN echo "www-data ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Crea la directory di lavoro (previene errori di mount)
RUN mkdir -p /var/www/html && chown -R www-data:www-data /var/www/html

WORKDIR /var/www/html

EXPOSE 80
