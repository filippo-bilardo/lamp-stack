{
    "name": "LAMP Stack",
    "dockerComposeFile": "docker-compose.yml",
    "service": "web",
    "workspaceFolder": "/var/www/html",
    "shutdownAction": "stopCompose",
    "remoteUser": "www-data",
    "postCreateCommand": "sudo mkdir -p /var/www/html && sudo chown -R www-data:www-data /var/www/html && sudo a2enmod rewrite && sudo service apache2 restart",
    "customizations": {
        "vscode": {
            "extensions": [
                "bmewburn.vscode-intelephense-client",
                "xdebug.php-debug"
            ]
        }
    },
    "forwardPorts": [80, 8080]
}
